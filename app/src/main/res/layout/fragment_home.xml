<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"> <!-- 极其淡的灰蓝色背景，让白色卡片更凸显 -->

    <!-- 顶部的大标题 -->
    <TextView
        android:id="@+id/tv_home_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="我的主子"
        android:textColor="#333333"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 👇 🌟 新增：临时用来测试打工人的红色警报按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_test_reminder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:text="测试 10秒后提醒"
        app:backgroundTint="#F44336"
        app:layout_constraintBottom_toBottomOf="@id/tv_home_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_home_title" />

    <!-- 宠物信息大卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_pet_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_home_title">

        <!-- 卡片内部的布局 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 宠物头像模具 (宽高 72dp，圆角 36dp) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_avatar_container"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="36dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- 头像本体 -->
                <ImageView
                    android:id="@+id/iv_pet_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E0E0E0"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>


            <!-- 宠物名字 -->
            <TextView
                android:id="@+id/tv_pet_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="旺财"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/card_avatar_container"
                app:layout_constraintTop_toTopOf="@id/card_avatar_container" />

            <!-- 宠物基本状态 -->
            <TextView
                android:id="@+id/tv_pet_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="金毛犬  |  2岁3个月  |  15.5 kg"
                android:textColor="#666666"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/tv_pet_name"
                app:layout_constraintTop_toBottomOf="@id/tv_pet_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="添加新宠物"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
